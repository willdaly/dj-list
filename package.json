{
  "name": "dj-list",
  "repository": {
    "type": "git",
    "url": "https://github.com/willdaly/dj-list"
  },
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "start": "npm run build:styles && node server.js",
    "build:styles": "lessc app/less/app.less app/static/css/app.css",
    "build:frontend": "vite build",
    "build:frontend:react": "vite build --config app/frontend-react/vite.config.ts",
    "dev:frontend": "vite --config app/frontend-react/vite.config.ts",
    "dev:frontend:legacy": "vite",
    "typecheck:frontend": "tsc --project app/frontend-react/tsconfig.json --noEmit",
    "lint:frontend": "eslint --config eslint.frontend.config.js \"app/frontend-react/src/**/*.{ts,tsx}\"",
    "test:frontend": "vitest run --config app/frontend-react/vitest.config.ts",
    "check:frontend": "npm run typecheck:frontend && npm run lint:frontend",
    "setup": "npm install",
    "test": "NODE_ENV=test mocha --require test/helpers/mocha-hooks.js test/types --recursive -R spec -t 5000",
    "watch": "NODE_ENV=test mocha --require test/helpers/mocha-hooks.js test/types --recursive -R spec -t 5000 --watch",
    "test:smoke": "npm run build:frontend && playwright test"
  },
  "dependencies": {
    "async": "^3.2.6",
    "bcrypt": "^6.0.0",
    "bootstrap": "^3.4.1",
    "cookie-session": "^2.1.1",
    "cookies": "^0.9.1",
    "dotenv": "^17.3.1",
    "express": "^5.1.0",
    "jquery": "^3.7.1",
    "less": "^4.6.3",
    "lodash": "^4.17.21",
    "moment": "^2.30.1",
    "mongodb": "^6.20.0",
    "morgan": "^1.10.1",
    "nouislider": "^15.8.1",
    "pug": "^3.0.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.3",
    "sortablejs": "^1.15.7",
    "wnumb": "^1.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "chai": "^6.2.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^28.1.0",
    "mocha": "^11.7.4",
    "superagent": "^10.2.3",
    "supertest": "^7.1.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.1.7",
    "vitest": "^4.1.0"
  }
}
