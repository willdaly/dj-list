{
  "name": "server-template",
  "repository": {
    "type": "git",
    "url": "https://github.com/nss-cohort-2014-04-07/server-template"
  },
  "version": "0.0.1",
  "private": true,
  "bin": {
    "coveralls": "./node_modules/coveralls/bin/coveralls.js"
  },
  "scripts": {
    "start": "node server.js",
    "build:frontend": "vite build",
    "dev:frontend": "vite",
    "setup": "npm install",
    "test": "NODE_ENV=test mocha --require test/helpers/mocha-hooks.js test/types --recursive -R spec -t 5000",
    "watch": "NODE_ENV=test mocha --require test/helpers/mocha-hooks.js test/types --recursive -R spec -t 5000 --watch",
    "coveralls": "NODE_ENV=test ./node_modules/mocha/bin/mocha --require test/helpers/mocha-hooks.js test/types --recursive -r blanket -R mocha-lcov-reporter | coveralls"
  },
  "dependencies": {
    "async": "^3.2.6",
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.0",
    "bootstrap": "^3.4.1",
    "cookie-session": "^2.1.1",
    "cookies": "^0.9.1",
    "express": "^5.1.0",
    "express-less": "^0.1.0",
    "jquery": "^3.7.1",
    "jquery-ui-dist": "^1.13.3",
    "lodash": "^4.17.21",
    "mailgun-js": "^0.22.0",
    "method-override": "^3.0.0",
    "moment": "^2.30.1",
    "mongodb": "^6.20.0",
    "morgan": "^1.10.1",
    "nouislider": "^15.8.1",
    "pug": "^3.0.3",
    "request": "^2.88.2",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.3",
    "wnumb": "^1.2.0"
  },
  "devDependencies": {
    "blanket": "^1.2.3",
    "chai": "^6.2.0",
    "coveralls": "^3.1.1",
    "grunt": "^1.6.1",
    "grunt-contrib-jshint": "^3.2.0",
    "grunt-contrib-watch": "^1.1.0",
    "jshint-stylish": "^2.2.1",
    "mocha": "^11.7.4",
    "mocha-lcov-reporter": "^1.3.0",
    "superagent": "^10.2.3",
    "supertest": "^7.1.4",
    "vite": "^7.1.7"
  },
  "config": {
    "blanket": {
      "pattern": "/app/"
    }
  }
}
