{
  "name": "server-template",
  "repository": {
    "type": "git",
    "url": "https://github.com/nss-cohort-2014-04-07/server-template"
  },
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "start": "npm run build:styles && node server.js",
    "build:styles": "lessc app/less/app.less app/static/css/app.css",
    "build:frontend": "vite build",
    "dev:frontend": "vite",
    "setup": "npm install",
    "test": "NODE_ENV=test mocha --require test/helpers/mocha-hooks.js test/types --recursive -R spec -t 5000",
    "watch": "NODE_ENV=test mocha --require test/helpers/mocha-hooks.js test/types --recursive -R spec -t 5000 --watch"
  },
  "dependencies": {
    "async": "^3.2.6",
    "bcrypt": "^6.0.0",
    "bootstrap": "^3.4.1",
    "cookie-session": "^2.1.1",
    "cookies": "^0.9.1",
    "dotenv": "^17.3.1",
    "express": "^5.1.0",
    "jquery": "^3.7.1",
    "less": "^4.6.3",
    "lodash": "^4.17.21",
    "moment": "^2.30.1",
    "mongodb": "^6.20.0",
    "morgan": "^1.10.1",
    "nouislider": "^15.8.1",
    "pug": "^3.0.3",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.3",
    "sortablejs": "^1.15.7",
    "wnumb": "^1.2.0"
  },
  "devDependencies": {
    "chai": "^6.2.0",
    "grunt": "^1.6.1",
    "grunt-contrib-jshint": "^3.2.0",
    "grunt-contrib-watch": "^1.1.0",
    "jshint-stylish": "^2.2.1",
    "mocha": "^11.7.4",
    "superagent": "^10.2.3",
    "supertest": "^7.1.4",
    "vite": "^7.1.7"
  }
}
