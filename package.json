{
  "name": "server-template",
  "repository": {
    "type": "git",
    "url": "https://github.com/nss-cohort-2014-04-07/server-template"
  },
  "version": "0.0.1",
  "private": true,
  "bin": {
    "coveralls": "./node_modules/coveralls/bin/coveralls.js"
  },
  "scripts": {
    "start": "node app/app.js",
    "setup": "npm install",
    "test": "NODE_ENV=test mocha test/types --recursive -R spec -t 5000",
    "watch": "NODE_ENV=test mocha test/types --recursive -R spec -t 5000 --watch",
    "coveralls": "NODE_ENV=test ./node_modules/mocha/bin/mocha test/types --recursive -r blanket -R mocha-lcov-reporter | coveralls"
  },
  "dependencies": {
    "async": "*",
    "bcrypt": "*",
    "body-parser": "*",
    "cookie-session": "*",
    "cookies": "*",
    "express": "*",
    "express-less": "*",
    "jade": "*",
    "lodash": "*",
    "mailgun-js": "*",
    "method-override": "*",
    "moment": "*",
    "mongodb": "^3.7.4",
    "morgan": "*",
    "request": "*",
    "socket.io": "*"
  },
  "devDependencies": {
    "blanket": "*",
    "chai": "*",
    "coveralls": "*",
    "grunt": "*",
    "grunt-contrib-jshint": "*",
    "grunt-contrib-watch": "*",
    "jshint-stylish": "*",
    "mocha": "*",
    "mocha-lcov-reporter": "*",
    "superagent": "*",
    "supertest": "*"
  },
  "config": {
    "blanket": {
      "pattern": "/app/"
    }
  }
}
