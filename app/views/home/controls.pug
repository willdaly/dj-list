.col-sm-3
  ul( class='nav nav-pills nav-justified', role='tablist')
    li.active
      a(data-target='#')#songsButton Songs
    li
      a(data-target='#')#playlistsButton Playlists
  .container
    .row.songs
      .control-label Genres
      ul.genres
        li.is-selected Hip-Hop
        li Hip-Hop Instrumental
        li Battle
        li 45 King
        li Soul
        li Jazz
        li Rock
        li Pop
        li(value='Electronic') Electronic
        li(value='Melodiya') Melodiya
        li(value='OST') OST

    .row.songs
      .control-label Key
      .input-group#keyinput
        select.form-control#key
          option AbM
          option abm
          option AM
          option am
          option BbM
          option bbm
          option BM
          option bm
          option CM
          option cm
          option C#M
          option c#m
          option DM
          option dm
          option EbM
          option ebm
          option EM
          option em
          option FM
          option fm
          option F#M
          option f#m
          option GM
          option gm
          option G#M
          option g#m
        span.input-group-btn
          button.btn.btn-default.dropdown-toggle(type='button', data-toggle='dropdown')#transpose Transpose
            span.caret
          ul#tp.dropdown-menu
            li(value='-1')
              a(data-target='#').transpose -1
            li(value='1')
              a(data-target='#').transpose +1
            li(value='-2')
              a(data-target='#').transpose -2
            li(value='2')
              a(data-target='#').transpose +2
            li(value='-3')
              a(data-target='#').transpose -3
            li(value='3')
              a(data-target='#').transpose +3
            li(value='-4')
              a(data-target='#').transpose -4
            li(value='4')
              a(data-target='#').transpose +4
            li(value='-5')
              a(data-target='#').transpose -5
            li(value='5')
              a(data-target='#').transpose +5
    .row.songs
      .slider-label BPM
      .slider
      .bpm-range#bpmRangeDisplay Range: 88 - 102

    .row.songs
      button.btn.btn-default.btn-lg#bpmKeyFilter Search
    
    .row.songs
      .input-group
        input.form-control(type='text', name='search', placeholder='Artist, Album, Song')#searchInput
        .input-group-btn
          button.btn.btn-default(type='button')#searchButton Search
      
    .row.playlistsIndex(style='display: none')
      .input-group
        input.form-control(type='text', name='name', id='name', placeholder='check songs, enter name')
        span.input-group-btn
          button.btn.btn-default(type='button')#createPlaylist Create Playlist
    .row      
      ul#playlists.list-group
      
    .row.playlistsShow(style='display: none')
      .btn-group
        button.btn.btn-default(type='button')#deleteFromPlaylist Remove Songs 
    .row.playlistsShow(style='display: none')
      .input-group
        input.form-control(type='text', id='editPlaylistName')
        span.input-group-btn
          button.btn.btn-default(type='button')#renamePlaylist Rename Playlist
    .row.playlistsShow(style='display: none')    
      button.btn.btn-small.btn-warning#deletePlaylist(type='button') Delete Playlist
  button.btn.btn-default#controlsToggle show / hide controls    
